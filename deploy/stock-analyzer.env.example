# Copy to /etc/stock-analyzer/stock-analyzer.env on the server.
# Keep permissions tight: sudo chmod 600 /etc/stock-analyzer/stock-analyzer.env

TELEGRAM_BOT_TOKEN=replace-with-bot-token
TELEGRAM_CHAT_ID=replace-with-your-chat-id
ALLOWED_TELEGRAM_CHAT_IDS=replace-with-your-chat-id

SEC_USER_AGENT=stock-analyzer/0.1 personal research your-real-email@example.com
FMP_API_KEY=

STOCK_ANALYZER_DB_PATH=/opt/stock-analyzer/data/stock_analyzer.sqlite3
STOCK_ANALYZER_DRY_RUN=false
STOCK_ANALYZER_INTERVAL_HOURS=3
STOCK_ANALYZER_ALERT_BUDGET=250
STOCK_ANALYZER_ALERT_SCORE_THRESHOLD=78
STOCK_ANALYZER_TOP_N=10
STOCK_ANALYZER_SEND_ONLY_ALERTS=false

STOCK_ANALYZER_CATALYST_PROVIDER=sec
STOCK_ANALYZER_CATALYST_TOP_N=12
STOCK_ANALYZER_SEC_LOOKBACK_DAYS=14
STOCK_ANALYZER_SEC_MAX_FILINGS=20

STOCK_ANALYZER_INCLUDE_SP500=true
STOCK_ANALYZER_EXTRA_SYMBOLS=SMCI,ARM,SOUN,MU,SNDK,MRVL,INTC,NVDA,AMD,AVGO,TSM,ASML,PLTR,CRWD,NET,IONQ,RGTI,QBTS,ASTS,RKLB
STOCK_ANALYZER_PROVIDER=yfinance
STOCK_ANALYZER_HISTORY_PERIOD=1y
STOCK_ANALYZER_HISTORY_INTERVAL=1d
STOCK_ANALYZER_MAX_SYMBOLS_PER_BATCH=120
STOCK_ANALYZER_REQUEST_TIMEOUT_SECONDS=20
STOCK_ANALYZER_TIMEZONE=America/Los_Angeles
