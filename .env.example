# Copy this file to .env or export the values in your shell/systemd service.

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# Comma-separated allowlist. For MVP this should usually match TELEGRAM_CHAT_ID exactly.
ALLOWED_TELEGRAM_CHAT_IDS=

# Runtime
STOCK_ANALYZER_DB_PATH=data/stock_analyzer.sqlite3
STOCK_ANALYZER_DRY_RUN=true
STOCK_ANALYZER_INTERVAL_HOURS=3
STOCK_ANALYZER_ALERT_BUDGET=250
STOCK_ANALYZER_ALERT_SCORE_THRESHOLD=78
STOCK_ANALYZER_TOP_N=10
STOCK_ANALYZER_SEND_ONLY_ALERTS=false

# Catalyst enrichment
# sec = free EDGAR filings. fmp/finnhub = optional news/earnings/analyst enrichment.
STOCK_ANALYZER_CATALYST_PROVIDER=sec
STOCK_ANALYZER_CATALYST_TOP_N=12
STOCK_ANALYZER_CATALYST_LOOKBACK_HOURS=72
STOCK_ANALYZER_CATALYST_MAX_NEWS_ARTICLES=6
# Free-plan guardrail: 5 symbols x 4 endpoints x 8 daily runs = up to 160 calls/day.
STOCK_ANALYZER_FMP_MAX_SYMBOLS_PER_RUN=5
STOCK_ANALYZER_FINNHUB_MAX_SYMBOLS_PER_RUN=5
STOCK_ANALYZER_MARKETAUX_MAX_SYMBOLS_PER_RUN=5
STOCK_ANALYZER_MARKETAUX_MIN_MATCH_SCORE=10
STOCK_ANALYZER_ALPHA_VANTAGE_MAX_SYMBOLS_PER_RUN=10
STOCK_ANALYZER_ALPHA_VANTAGE_DAILY_CALL_BUDGET=20
SEC_USER_AGENT=stock-analyzer/0.1 personal research your-email@example.com
STOCK_ANALYZER_SEC_LOOKBACK_DAYS=14
STOCK_ANALYZER_SEC_MAX_FILINGS=20
FMP_API_KEY=
FINNHUB_API_KEY=
MARKETAUX_API_TOKEN=
ALPHA_VANTAGE_API_KEY=
FRED_API_KEY=

# Universe
# Leave true for the live S&P 500 list from Wikipedia. If it fails, the app uses a curated fallback.
STOCK_ANALYZER_INCLUDE_SP500=true
STOCK_ANALYZER_EXTRA_SYMBOLS=SMCI,ARM,SOUN,MU,SNDK,MRVL,INTC,NVDA,AMD,AVGO,TSM,ASML,PLTR,CRWD,NET,IONQ,RGTI,QBTS,ASTS,RKLB
STOCK_ANALYZER_SYMBOLS=
STOCK_ANALYZER_MAX_SYMBOLS=

# Data provider
STOCK_ANALYZER_PROVIDER=yfinance
STOCK_ANALYZER_HISTORY_PERIOD=1y
STOCK_ANALYZER_HISTORY_INTERVAL=1d
STOCK_ANALYZER_MAX_SYMBOLS_PER_BATCH=120
STOCK_ANALYZER_MIN_MARKET_COVERAGE_PCT=90
STOCK_ANALYZER_REQUEST_TIMEOUT_SECONDS=20
STOCK_ANALYZER_TIMEZONE=America/Los_Angeles
